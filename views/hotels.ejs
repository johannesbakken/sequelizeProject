<!DOCTYPE html>
<html>
  <head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/stylesheets/hotels.css" rel="stylesheet">
  </head>
  <body>
    <%- include("./partials/navbar.ejs") %>
    <section>
      <h2 class="p-3">Choose a hotel</h2>
      <div class="list-group">
        <% hotels.forEach(function(hotel) { %>
          <div class="row px-3 py-1 w-100">
            <span class="col py-1 bg-info"><%=hotel.Name%><span class="right"><%=hotel.Location%></span></span>
            <a href="/rooms/<%=hotel.id%>" class="col btn btn-secondary"> Rent a room</a>
            <a href="/hotels/<%=hotel.id%>" class="col btn btn-secondary"> Details</a>
            <button class="col btn btn-secondary" onclick="deleteHotel('http\:\/\/localhost:3000\/hotels\/', '<%=hotel.id%>')">Remove Hotel</button>
        <% }); %>
      </div>
      <div>
          <button onclick="addHotel('http:\/\/localhost:3000\/hotels\/')" class="right btn btn-success">Add Hotel</button>
      </div>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
      <script src="../javascripts/deleteHotel.js"></script>
      <script src="../javascripts/addHotel.js"></script>
    </section>
  </body>
</html>